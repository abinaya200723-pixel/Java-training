class Student {

    // Data members
    int id;
    String name;
    int age;

    // Constructor
    Student(int id, String name, int age) {
        this.id = id;
        this.name = name;
        this.age = age;
    }

    // Method
    void display() {
        System.out.println("Student ID: " + id);
        System.out.println("Student Name: " + name);
        System.out.println("Student Age: " + age);
    }
}

public class Main {
    public static void main(String[] args) {

        // Creating objects using constructor
        Student s1 = new Student(101, "Abi", 20);
        Student s2 = new Student(102, "Naya", 19);

        // Calling method
        s1.display();
        System.out.println();

        s2.display();
    }
}